#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-push checks..."
echo ""

# Backend linting
echo "🧹 Running backend linter..."
cd backend && npm run lint
if [ $? -ne 0 ]; then
  echo "❌ Backend linting failed. Push aborted."
  exit 1
fi

# Backend unit tests (only unit, not integration - those run separately below)
echo ""
echo "🧪 Running backend unit tests..."
npm run test:unit
if [ $? -ne 0 ]; then
  echo "❌ Backend unit tests failed. Push aborted."
  exit 1
fi

# Backend integration tests
echo ""
echo "🔗 Running backend integration tests..."

# Try to manage Docker Redis, but don't fail if Docker CLI has issues
# NOTE: Docker CLI may return 500 errors on Windows when Docker Desktop has API issues
# We handle this gracefully and assume Redis is available on the configured port
STARTED_REDIS=false
if command -v docker >/dev/null 2>&1; then
  # Check if Redis test container is running (handle Docker CLI errors gracefully)
  # The || true prevents script exit if Docker CLI fails (e.g., 500 errors)
  DOCKER_PS_OUTPUT=$(docker ps --format '{{.Names}}' 2>&1 || true)
  if echo "$DOCKER_PS_OUTPUT" | grep -q 'bc-agent-redis-test'; then
    echo "✅ Redis test container already running"
  elif echo "$DOCKER_PS_OUTPUT" | grep -q 'Error\|error\|500\|request returned'; then
    echo "⚠️  Docker CLI error detected. Assuming Redis is available on configured port."
  else
    echo "🐳 Starting Redis test container..."
    if docker-compose -f docker-compose.test.yml up -d 2>/dev/null; then
      # Wait for Redis to be ready
      echo "⏳ Waiting for Redis to be ready..."
      timeout=30
      while [ $timeout -gt 0 ]; do
        if docker exec bc-agent-redis-test redis-cli ping >/dev/null 2>&1; then
          echo "✅ Redis is ready"
          break
        fi
        sleep 1
        timeout=$((timeout - 1))
      done

      if [ $timeout -eq 0 ]; then
        echo "⚠️  Redis container failed to start. Integration tests may fail."
      fi
      STARTED_REDIS=true
    else
      echo "⚠️  Failed to start Docker Redis. Using existing Redis (if configured)."
    fi
  fi
else
  echo "⚠️  Docker not available. Using existing Redis (if configured)."
fi

# Integration tests are MANDATORY - Redis must be available
# Either via Docker container (started above) or local/CI Redis instance
npm run test:integration
if [ $? -ne 0 ]; then
  echo "❌ Backend integration tests failed. Push aborted."
  echo "💡 Ensure Redis is running (docker-compose -f docker-compose.test.yml up -d)"
  exit 1
fi

# Clean up Redis container if we started it
if [ "$STARTED_REDIS" = true ]; then
  echo "🧹 Stopping Redis test container..."
  docker-compose -f docker-compose.test.yml down >/dev/null 2>&1
fi

# Backend build
echo ""
echo "🏗️  Building backend..."
npm run build
if [ $? -ne 0 ]; then
  echo "❌ Backend build failed. Push aborted."
  exit 1
fi

# Frontend linting
echo ""
echo "🧹 Running frontend linter..."
cd ../frontend && npm run lint
if [ $? -ne 0 ]; then
  echo "❌ Frontend linting failed. Push aborted."
  exit 1
fi

# Frontend tests
echo ""
echo "🧪 Running frontend tests..."
npm test
if [ $? -ne 0 ]; then
  echo "❌ Frontend tests failed. Push aborted."
  exit 1
fi

# Full type-check (shared + backend + frontend, catches test file errors that builds miss)
echo ""
echo "🔎 Running full type-check..."
cd .. && npm run verify:types
if [ $? -ne 0 ]; then
  echo "❌ Type-check failed. Push aborted."
  exit 1
fi

# Frontend build
echo ""
echo "🏗️  Building frontend..."
cd frontend && npm run build
if [ $? -ne 0 ]; then
  echo "❌ Frontend build failed. Push aborted."
  exit 1
fi

echo ""
echo "✅ All checks passed. Pushing..."
